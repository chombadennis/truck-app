{
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "truck-backend",
    "runtime": "python311"
  },
  "hosting": {
    "public": "truck-frontend/build",
    "predeploy": [
      "npm --prefix truck-frontend install",
      "npm --prefix truck-frontend run build"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}